# Email Configuration (Choose ONE option below)

# Option 1: Gmail SMTP (Recommended for quick setup)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an App Password for Gmail
# 3. Set these environment variables:
EMAIL_USE_SMTP=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password-here

# Option 2: Gmail API Service Account (OAuth2)
# Only uncomment if you have proper service account setup with delegated authority
# EMAIL_USE_SMTP=false
# CLIENT_SECRET_FILE=client_secret.json

# Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DB=hostelconnect_db
